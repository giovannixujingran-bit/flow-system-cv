STORAGE_MODE=memory
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/flow_system
RUN_MIGRATIONS=false
IMPORT_CURRENT_STATE=false
FAIL_IF_DB_EMPTY_AND_NO_IMPORT=true

FLOW_SEED_MODE=managed
PORT=4010
HOST=127.0.0.1
APP_ORIGIN=http://127.0.0.1:3000

STORAGE_ROOT=./storage
PLATFORM_STATE_SNAPSHOT_FILE=./storage/platform-state.json
MANAGED_USERS_FILE=./account-management/managed-users.json
MANAGED_USERS_SUMMARY_FILE=./account-management/accounts-summary.txt
