<Window
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Title="Flow Overlay"
  Width="404"
  Height="668"
  Topmost="True"
  WindowStyle="None"
  ResizeMode="NoResize"
  AllowsTransparency="True"
  Background="Transparent"
  ShowInTaskbar="False">
  <Window.Resources>
    <SolidColorBrush x:Key="OverlayPanelBrush" Color="#EAF7F8FA" />
    <SolidColorBrush x:Key="OverlayPanelBorderBrush" Color="#F2FFFFFF" />
    <SolidColorBrush x:Key="OverlayCardBrush" Color="#A6FFFFFF" />
    <SolidColorBrush x:Key="OverlayInputBrush" Color="#F9FFFFFF" />
    <SolidColorBrush x:Key="OverlayTaskCardBrush" Color="#F9FFFFFF" />
    <SolidColorBrush x:Key="OverlayTaskCardBorderBrush" Color="#160F172A" />
    <SolidColorBrush x:Key="OverlayTaskCardHoverBrush" Color="#FCFFFFFF" />
    <SolidColorBrush x:Key="OverlayTaskChipBrush" Color="#C2FFFFFF" />
    <SolidColorBrush x:Key="OverlayTaskChipBorderBrush" Color="#140F172A" />
    <SolidColorBrush x:Key="OverlayTaskAvatarBrush" Color="#E6E2E8F0" />
    <SolidColorBrush x:Key="OverlayStrokeBrush" Color="#160F172A" />
    <SolidColorBrush x:Key="OverlayMutedTextBrush" Color="#6B7280" />
    <CornerRadius x:Key="OverlayTaskCardCornerRadius">24</CornerRadius>
    <RadialGradientBrush x:Key="OrbHaloBrush" Center="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
      <GradientStop Color="#88DDF5FF" Offset="0" />
      <GradientStop Color="#36BFE8FF" Offset="0.42" />
      <GradientStop Color="#081E293B" Offset="1" />
    </RadialGradientBrush>
    <RadialGradientBrush x:Key="OrbShellBrush" Center="0.42,0.34" RadiusX="0.72" RadiusY="0.72">
      <GradientStop Color="#FFFFFFFF" Offset="0" />
      <GradientStop Color="#F2F8FCFF" Offset="0.55" />
      <GradientStop Color="#C4E8F6FF" Offset="0.82" />
      <GradientStop Color="#98D7ECFF" Offset="1" />
    </RadialGradientBrush>
    <RadialGradientBrush x:Key="OrbCoreBrush" Center="0.5,0.5" RadiusX="0.7" RadiusY="0.7">
      <GradientStop Color="#FFFFFFFF" Offset="0" />
      <GradientStop Color="#FFF6FBFF" Offset="0.38" />
      <GradientStop Color="#FFDDF6FF" Offset="0.7" />
      <GradientStop Color="#FFAFDFFF" Offset="1" />
    </RadialGradientBrush>
    <LinearGradientBrush x:Key="OrbAccentStrokeBrush" StartPoint="0,0" EndPoint="1,1">
      <GradientStop Color="#FFF7FCFF" Offset="0" />
      <GradientStop Color="#FF8EE7FF" Offset="0.5" />
      <GradientStop Color="#FF1E3A8A" Offset="1" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="OrbSecondaryStrokeBrush" Color="#A0F8FDFF" />

    <Style x:Key="RoundedButtonStyle" TargetType="Button">
      <Setter Property="Background" Value="#F7FFFFFF" />
      <Setter Property="Foreground" Value="#0F172A" />
      <Setter Property="BorderBrush" Value="{StaticResource OverlayStrokeBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="FocusVisualStyle" Value="{x:Null}" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border
              Background="{TemplateBinding Background}"
              BorderBrush="{TemplateBinding BorderBrush}"
              BorderThickness="{TemplateBinding BorderThickness}"
              CornerRadius="18"
              SnapsToDevicePixels="True">
              <ContentPresenter
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Margin="{TemplateBinding Padding}" />
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="SegmentButtonStyle" TargetType="Button" BasedOn="{StaticResource RoundedButtonStyle}">
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border
              Background="{TemplateBinding Background}"
              BorderBrush="{TemplateBinding BorderBrush}"
              BorderThickness="{TemplateBinding BorderThickness}"
              CornerRadius="20"
              SnapsToDevicePixels="True">
              <ContentPresenter
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Margin="{TemplateBinding Padding}" />
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="OrbButtonStyle" TargetType="Button">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="FocusVisualStyle" Value="{x:Null}" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <ContentPresenter
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch"
              Margin="{TemplateBinding Padding}" />
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="TaskCardButtonStyle" TargetType="Button">
      <Setter Property="Background" Value="{StaticResource OverlayTaskCardBrush}" />
      <Setter Property="Foreground" Value="#0F172A" />
      <Setter Property="BorderBrush" Value="{StaticResource OverlayTaskCardBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="14" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="FocusVisualStyle" Value="{x:Null}" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="VerticalContentAlignment" Value="Stretch" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border
              x:Name="CardSurface"
              Background="{TemplateBinding Background}"
              BorderBrush="{TemplateBinding BorderBrush}"
              BorderThickness="{TemplateBinding BorderThickness}"
              CornerRadius="{StaticResource OverlayTaskCardCornerRadius}"
              SnapsToDevicePixels="True">
              <ContentPresenter
                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                Margin="{TemplateBinding Padding}" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="CardSurface" Property="Background" Value="{StaticResource OverlayTaskCardHoverBrush}" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="CardSurface" Property="Opacity" Value="0.96" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Grid>
    <Grid
      x:Name="CollapsedRoot"
      Panel.ZIndex="0"
      Width="88"
      Height="88"
      HorizontalAlignment="Left"
      VerticalAlignment="Top">
      <Button
        x:Name="OrbButton"
        Width="88"
        Height="88"
        Padding="0"
        Style="{StaticResource OrbButtonStyle}">
        <Grid>
          <Ellipse
            x:Name="OrbHalo"
            Width="82"
            Height="82"
            Opacity="0.94">
            <Ellipse.Fill>
              <RadialGradientBrush Center="0.5,0.5" RadiusX="0.54" RadiusY="0.54">
                <GradientStop Color="#74FF5F9C" Offset="0" />
                <GradientStop Color="#24FF5F9C" Offset="0.44" />
                <GradientStop Color="#0023153C" Offset="1" />
              </RadialGradientBrush>
            </Ellipse.Fill>
            <Ellipse.Effect>
              <BlurEffect Radius="19" />
            </Ellipse.Effect>
          </Ellipse>
          <Border
            x:Name="OrbBorder"
            CornerRadius="44"
            Background="#1223153C"
            BorderBrush="#24FFF8FB"
            BorderThickness="1">
            <Border.Effect>
              <DropShadowEffect Color="#A0FF5F9C" BlurRadius="24" ShadowDepth="0" Opacity="0.82" />
            </Border.Effect>
            <Grid>
              <Ellipse
                x:Name="OrbSurface"
                Width="74"
                Height="74"
                Fill="#FF23153C"
                Stroke="#20FFF8FB"
                StrokeThickness="1.1" />
              <Ellipse
                x:Name="OrbAtmosphere"
                Width="77"
                Height="77"
                Stroke="#18FFF8FB"
                StrokeThickness="1"
                Opacity="0.86" />
              <Grid
                Width="74"
                Height="74"
                IsHitTestVisible="False">
                <Grid.Clip>
                  <EllipseGeometry Center="37,37" RadiusX="35.5" RadiusY="35.5" />
                </Grid.Clip>
                <Ellipse
                  x:Name="OrbSurfaceGlow"
                  Width="74"
                  Height="74"
                  Opacity="0.42">
                  <Ellipse.Fill>
                    <RadialGradientBrush Center="0.34,0.28" RadiusX="0.7" RadiusY="0.7">
                      <GradientStop Color="#40FFF8FB" Offset="0" />
                      <GradientStop Color="#14FF5F9C" Offset="0.42" />
                      <GradientStop Color="#0023153C" Offset="1" />
                    </RadialGradientBrush>
                  </Ellipse.Fill>
                </Ellipse>
                <Canvas Width="74" Height="74">
                  <Canvas.RenderTransform>
                    <RotateTransform x:Name="OrbPrimaryWireRotate" CenterX="37" CenterY="37" />
                  </Canvas.RenderTransform>
                  <Ellipse x:Name="OrbPrimaryMeridianA" Width="28" Height="72" Canvas.Left="23" Canvas.Top="1" Stroke="#FFFF5F9C" StrokeThickness="1.85" />
                  <Ellipse x:Name="OrbPrimaryMeridianB" Width="46" Height="72" Canvas.Left="14" Canvas.Top="1" Stroke="#66FFF8FB" StrokeThickness="1.15" />
                  <Ellipse x:Name="OrbPrimaryMeridianC" Width="60" Height="72" Canvas.Left="7" Canvas.Top="1" Stroke="#66FFF8FB" StrokeThickness="1.05" />
                </Canvas>
                <Canvas Width="74" Height="74">
                  <Canvas.RenderTransform>
                    <RotateTransform x:Name="OrbSecondaryWireRotate" CenterX="37" CenterY="37" />
                  </Canvas.RenderTransform>
                  <Ellipse x:Name="OrbSecondaryLatitudeA" Width="72" Height="20" Canvas.Left="1" Canvas.Top="26" Stroke="#66FFF8FB" StrokeThickness="1.05" />
                  <Ellipse x:Name="OrbSecondaryLatitudeB" Width="72" Height="36" Canvas.Left="1" Canvas.Top="18" Stroke="#FFFF5F9C" StrokeThickness="1.75" />
                  <Ellipse x:Name="OrbSecondaryLatitudeC" Width="72" Height="50" Canvas.Left="1" Canvas.Top="11" Stroke="#66FFF8FB" StrokeThickness="1.05" />
                </Canvas>
                <Path
                  x:Name="OrbHighlightArcPrimary"
                  Data="M 25,21 C 32,13 43,9 56,11"
                  Stroke="#74FFF8FB"
                  StrokeThickness="1.3"
                  StrokeStartLineCap="Round"
                  StrokeEndLineCap="Round"
                  Opacity="0.82" />
                <Path
                  x:Name="OrbHighlightArcSecondary"
                  Data="M 22,56 C 33,62 50,63 61,55"
                  Stroke="#8EFF5F9C"
                  StrokeThickness="1.2"
                  StrokeStartLineCap="Round"
                  StrokeEndLineCap="Round"
                  Opacity="0.92" />
              </Grid>
              <Canvas Width="82" Height="82" IsHitTestVisible="False">
                <Canvas.RenderTransform>
                  <RotateTransform x:Name="OrbPrimaryOrbitRotate" CenterX="41" CenterY="41" />
                </Canvas.RenderTransform>
                <Ellipse
                  x:Name="OrbOrbitPrimary"
                  Width="62"
                  Height="62"
                  Canvas.Left="10"
                  Canvas.Top="10"
                  Stroke="#34FFF8FB"
                  StrokeThickness="1" />
                <Ellipse
                  x:Name="OrbOrbitPrimaryDot"
                  Width="6"
                  Height="6"
                  Canvas.Left="66"
                  Canvas.Top="38"
                  Fill="#FFF8FB" />
              </Canvas>
              <Canvas Width="82" Height="82" IsHitTestVisible="False">
                <Canvas.RenderTransform>
                  <RotateTransform x:Name="OrbSecondaryOrbitRotate" CenterX="41" CenterY="41" />
                </Canvas.RenderTransform>
                <Ellipse
                  x:Name="OrbOrbitSecondary"
                  Width="72"
                  Height="42"
                  Canvas.Left="5"
                  Canvas.Top="20"
                  Stroke="#5CFF5F9C"
                  StrokeThickness="1" />
                <Ellipse
                  x:Name="OrbOrbitSecondaryDot"
                  Width="5"
                  Height="5"
                  Canvas.Left="6"
                  Canvas.Top="38.5"
                  Fill="#FFFF5F9C" />
              </Canvas>
            </Grid>
          </Border>
          <Border
            x:Name="UnreadBadge"
            Width="24"
            Height="24"
            CornerRadius="12"
            Background="#F6FFF8FB"
            BorderBrush="#54FF5F9C"
            BorderThickness="1"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Margin="0,-2,-2,0"
            Visibility="Collapsed">
            <TextBlock
              x:Name="UnreadBadgeText"
              Foreground="#23153C"
              FontSize="11"
              FontWeight="Bold"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Text="0" />
          </Border>
        </Grid>
      </Button>
    </Grid>

    <Border
      x:Name="ExpandedRoot"
      Panel.ZIndex="1"
      Width="404"
      Height="668"
      CornerRadius="32"
      Background="{StaticResource OverlayPanelBrush}"
      BorderBrush="{StaticResource OverlayPanelBorderBrush}"
      BorderThickness="1"
      Padding="14"
      Visibility="Collapsed">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid x:Name="HeaderDragGrip" Grid.Row="0" Margin="0,0,0,12">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <StackPanel>
            <TextBlock
              Text="FLOW OVERLAY"
              Foreground="{StaticResource OverlayMutedTextBrush}"
              FontSize="11"
              FontWeight="SemiBold" />
            <StackPanel
              Orientation="Horizontal"
              Margin="0,4,0,0"
              VerticalAlignment="Center">
              <Ellipse
                x:Name="HeaderStatusDot"
                Width="10"
                Height="10"
                Margin="0,0,10,0"
                VerticalAlignment="Center"
                Fill="#16A34A"
                Visibility="Visible" />
              <TextBlock
                x:Name="HeaderTitle"
                Text=""
                Foreground="#0F172A"
                FontSize="26"
                FontWeight="Bold"
                VerticalAlignment="Center" />
            </StackPanel>
          </StackPanel>
          <Button
            x:Name="CollapseButton"
            Grid.Column="1"
            Content=""
            Width="78"
            Height="36"
            Style="{StaticResource RoundedButtonStyle}" />
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,0,12">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <Button
            x:Name="ConversationTabButton"
            Grid.Column="0"
            Content=""
            Height="42"
            Margin="0,0,6,0"
            Style="{StaticResource SegmentButtonStyle}" />
          <Button
            x:Name="TasksTabButton"
            Grid.Column="1"
            Content=""
            Height="42"
            Margin="6,0,0,0"
            Style="{StaticResource SegmentButtonStyle}" />
        </Grid>

        <Grid Grid.Row="2">
          <Grid x:Name="ConversationPane">
            <Grid.RowDefinitions>
              <RowDefinition Height="*" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Border
              Grid.Row="0"
              CornerRadius="26"
              Background="{StaticResource OverlayCardBrush}"
              BorderBrush="#CFFFFFFF"
              BorderThickness="1"
              Padding="10">
              <ScrollViewer
                x:Name="MessagesScrollViewer"
                VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Disabled">
                <StackPanel x:Name="MessagesPanel" />
              </ScrollViewer>
            </Border>
            <Grid Grid.Row="1" Margin="0,10,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <Border
                Grid.Column="0"
                CornerRadius="24"
                Background="{StaticResource OverlayInputBrush}"
                BorderBrush="{StaticResource OverlayStrokeBrush}"
                BorderThickness="1"
                Padding="10">
                <TextBox
                  x:Name="ComposerInput"
                  Language="zh-CN"
                  AcceptsReturn="True"
                  TextWrapping="Wrap"
                  VerticalScrollBarVisibility="Auto"
                  MinHeight="64"
                  MaxHeight="78"
                  Background="Transparent"
                  BorderThickness="0"
                  Foreground="#0F172A"
                  FontSize="15"
                  SpellCheck.IsEnabled="False"
                  InputMethod.IsInputMethodEnabled="True"
                  InputMethod.PreferredImeState="On" />
              </Border>
              <Button
                x:Name="SendButton"
                Grid.Column="1"
                Content=""
                Width="78"
                Height="40"
                Margin="12,0,0,0"
                VerticalAlignment="Bottom"
                Style="{StaticResource RoundedButtonStyle}" />
            </Grid>
          </Grid>

          <Border
            x:Name="TasksPane"
            CornerRadius="26"
            Background="{StaticResource OverlayCardBrush}"
            BorderBrush="#CFFFFFFF"
            BorderThickness="1"
            Padding="10"
            Visibility="Collapsed">
            <ScrollViewer
              x:Name="TasksScrollViewer"
              VerticalScrollBarVisibility="Auto"
              HorizontalScrollBarVisibility="Disabled">
              <StackPanel x:Name="TasksPanel" />
            </ScrollViewer>
          </Border>
        </Grid>

        <Border
          x:Name="ErrorBanner"
          Grid.Row="3"
          Margin="0,12,0,0"
          CornerRadius="18"
          Background="#FFFCECEC"
          BorderBrush="#33DC2626"
          BorderThickness="1"
          Padding="10,8"
          Visibility="Collapsed">
          <TextBlock
            x:Name="ErrorText"
            Foreground="#B91C1C"
            FontSize="12"
            TextWrapping="Wrap" />
        </Border>
      </Grid>
    </Border>
  </Grid>
</Window>
